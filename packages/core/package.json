    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
