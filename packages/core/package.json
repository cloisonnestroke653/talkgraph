    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "better-sqlite3": ">=11.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.37",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.8.0",
    "typescript": "^6.0.2",
    "vitest": "^2.1.9"
